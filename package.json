{
  "name": "skyrent-drones",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "dev:sdk": "pnpm --filter @skyrent/identity-sdk dev",
    "build": "pnpm --filter @skyrent/identity-sdk build && pnpm --filter demo build",
    "build:sdk": "pnpm --filter @skyrent/identity-sdk build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
